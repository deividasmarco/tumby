{
  "expo": {
    "name": "Tumby",
    "slug": "tumby",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "tumby",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.tumbyapp.tumby",
      "buildNumber": "1",
      "usesAppleSignIn": true,
      "infoPlist": {
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.513060506294-m6nph1v5qbejje13vpp7q9dt3f5dimr8"
            ]
          },
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.513060506294-m6nph1v5qbejje13vpp7q9dt3f5dimr8"
            ]
          }
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.tumbyapp.tumby",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#FFFBF5"
      }
    },
    "web": {
      "favicon": "./assets/icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-web-browser",
      "expo-apple-authentication",
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "privacyPolicyUrl": "https://TODO-your-domain.com/tumby/privacy-policy",
      "termsUrl": "https://TODO-your-domain.com/tumby/terms",
      "router": {},
      "eas": {
        "projectId": "ac7750b1-3e51-44d6-bba6-ff67ff4c88fc"
      }
    }
  }
}

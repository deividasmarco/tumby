{
  "expo": {
    "name": "Yumly",
    "slug": "yumly",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "yumly",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.yumlyapp.yumly",
      "buildNumber": "1"
    },
    "android": {
      "package": "com.yumlyapp.yumly",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#FFFBF5"
      }
    },
    "web": {
      "favicon": "./assets/icon.png"
    },
    "plugins": ["expo-router"],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "privacyPolicyUrl": "https://TODO-your-domain.com/yumly/privacy-policy",
      "termsUrl": "https://TODO-your-domain.com/yumly/terms"
    }
  }
}

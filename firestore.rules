rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function ownsIncoming() {
      return isSignedIn() && request.resource.data.parentId == request.auth.uid;
    }

    function ownsExisting() {
      return isSignedIn() && resource.data.parentId == request.auth.uid;
    }

    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /children/{childId} {
      allow read, update, delete: if isSignedIn() && resource.data.parentId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.parentId == request.auth.uid;
    }

    // foodLogs and mealPlans authorize via a direct parentId field check.
    // No cross-document get() is used, so queries and batch deletes are not
    // subject to Firestore's ~20 get()/exists() per-request limit.
    match /foodLogs/{logId} {
      allow read, delete: if ownsExisting();
      allow create: if ownsIncoming();
    }

    match /mealPlans/{planId} {
      // resource is null when the doc doesn't exist yet (brand-new child's first load).
      allow get: if isSignedIn() && (resource == null || ownsExisting());
      allow list: if ownsExisting();
      allow create: if ownsIncoming();
      allow update: if ownsExisting() && ownsIncoming();
      allow delete: if ownsExisting();
    }
  }
}

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function ownsIncoming() { return isSignedIn() && request.resource.data.parentId == request.auth.uid; }
    function ownsExisting() { return isSignedIn() && resource.data.parentId == request.auth.uid; }

    // Fallback for legacy docs created before the parentId field existed:
    // authorize via the referenced child document's owner. New docs never reach
    // this (they short-circuit on ownsExisting()), so no get() is used at launch.
    function ownsChildOf(data) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/children/$(data.childId))
        && get(/databases/$(database)/documents/children/$(data.childId)).data.parentId == request.auth.uid;
    }

    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /children/{childId} {
      allow read, update, delete: if isSignedIn() && resource.data.parentId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.parentId == request.auth.uid;
    }

    match /foodLogs/{logId} {
      allow read, delete: if ownsExisting() || ownsChildOf(resource.data);
      allow create: if ownsIncoming();
    }

    match /mealPlans/{planId} {
      allow get: if isSignedIn() && (resource == null || ownsExisting() || ownsChildOf(resource.data));
      allow list: if ownsExisting() || ownsChildOf(resource.data);
      allow create: if ownsIncoming();
      allow update: if (ownsExisting() || ownsChildOf(resource.data)) && ownsIncoming();
      allow delete: if ownsExisting() || ownsChildOf(resource.data);
    }
  }
}
